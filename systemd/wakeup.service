[Unit]
Description=Bot wakeup — autonomous activity check
After=network-online.target bot-tg.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/bot
EnvironmentFile=/root/bot/bot.env
Environment=HOME=/root
ExecStart=/usr/bin/python3 /root/bot/wakeup.py
StandardOutput=append:/root/bot/wakeup.log
StandardError=append:/root/bot/wakeup.log
